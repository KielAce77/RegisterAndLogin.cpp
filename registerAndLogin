#include <iostream>
using namespace std;

int main()
{
    string RegisteredUsername, RegisteredPassword;
    string LogUsername, LogPassword;

    // Register
    cout << "--- Register ---" << endl;
    cout << "Enter username: ";
    cin >> RegisteredUsername;

    cout << "Enter password: ";
    cin >> RegisteredPassword;

    cout << "\nRegistration successful!\n\n";

    // Login
    cout << "--- Login ---" << endl;
    cout << "Enter username: ";
    cin >> LogUsername;

    cout << "Enter password: ";
    cin >> LogPassword;

    if (LogUsername == RegisteredUsername && LogPassword == RegisteredPassword)
    {
        cout << "Login successful!" << endl;
    }
    else
    {
        cout << "Invalid username or password." << endl;
    }

    return 0;
}
